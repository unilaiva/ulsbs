{
  "Chord definition (ULSBS)": {
    "prefix": "\\[",
    "body": "\\[${1}]",
    "description": "Insert \\[ ... ] (ULSBS). Place chord names within this."
  },

  "begin{songs} ... end{songs} (ULSBS)": {
    "prefix": [ "begin{songs}", "\\begin{songs}" ],
    "body": [
      "\\begin{songs}",
      "\t$0",
      "\\end{songs}"
    ],
    "description": "Insert songs environment. Songs must be within songs environments."
  },


  "begin{translation} ... end{translation} (ULSBS)": {
    "prefix": [ "translation", "\\begin{translation}" ],
    "body": [
      "\\begin{translation}[$1]",
      "\t$0",
      "\\end{translation}"
    ],
    "description": "Insert translation environment"
  },

  "begin{explanation} ... end{explanation} (ULSBS)": {
    "prefix": [ "explanation", "\\begin{explanation}" ],
    "body": [
      "\\begin{explanation}[$1]",
      "\t$0",
      "\\end{explanation}"
    ],
    "description": "Insert explanation environment"
  },

  "begin{passage} ... end{passage} (ULSBS)": {
    "prefix": [ "passage", "\\begin{passage}" ],
    "body": [
      "\\begin{passage}[$1]",
      "\t$0",
      "\\end{passage}"
    ],
    "description": "Insert passage environment"
  },

  "begin{feeler} ... end{feeler} (ULSBS)": {
    "prefix": [ "feeler", "\\begin{feeler}" ],
    "body": [
      "\\begin{feeler}",
      "\t$0",
      "\\end{feeler}"
    ],
    "description": "Insert feeler environment"
  },

  "begin{lilypond} ... end{lilypond} (ULSBS)": {
    "prefix": [ "lilypond", "\\begin{lilypond}" ],
    "body": [
      "\\begin{lilypond}",
      "\t$0",
      "\\end{lilypond}"
    ],
    "description": "Insert lilypond environment"
  },

  "begin{lilywrap+lilypond} ... end{lilypond+lilywrap} (ULSBS)": {
    "prefix": [ "lilywrap", "\\begin{lilywrap}" ],
    "body": [
      "\\begin{lilywrap}\\begin{lilypond}",
      "\t$0",
      "\\end{lilypond}\\end{lilywrap}"
    ],
    "description": "Insert lilywrap + lilypond environment"
  }
}
